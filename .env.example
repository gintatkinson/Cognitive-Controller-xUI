# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this dashboard is hosted.
APP_URL="MY_APP_URL"

# TFS INTEGRATION SETTINGS
# The base URL for the TFS Northbound REST API (exposed via GKE Ingress/LoadBalancer)
VITE_TFS_API_URL="https://tfs-api.example.com"

# The WebSocket URL for real-time network updates
VITE_TFS_WS_URL="wss://tfs-api.example.com/ws"

# KEYCLOAK AUTHENTICATION SETTINGS
# The base URL for the Keycloak server
VITE_KEYCLOAK_URL="https://keycloak.example.com"
VITE_KEYCLOAK_REALM="tfs"
VITE_KEYCLOAK_CLIENT_ID="tfs-dashboard"
